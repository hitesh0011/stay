package com.staynest.demo.aspect;

import com.staynest.demo.repositories.UsersRepository;
import com.staynest.demo.service.AuditLogService;
import lombok.RequiredArgsConstructor;
import org.aspectj.lang.JoinPoint;
import org.aspectj.lang.annotation.AfterReturning;
import org.aspectj.lang.annotation.Aspect;
import org.springframework.security.core.Authentication;
import org.springframework.security.core.context.SecurityContextHolder;
import org.springframework.stereotype.Component;

@Aspect
@Component
@RequiredArgsConstructor
public class AuditLoggingAspect {

    private final AuditLogService auditLogService;
    private final UsersRepository usersRepository;

    @AfterReturning("execution(* com.staynest.demo.serviceimpl.*ServiceImpl.create*(..)) || " +
                    "execution(* com.staynest.demo.serviceimpl.*ServiceImpl.update*(..)) || " +
                    "execution(* com.staynest.demo.serviceimpl.*ServiceImpl.delete*(..)) || " +
                    "execution(* com.staynest.demo.serviceimpl.*ServiceImpl.cancel*(..)) || " +
                    "execution(* com.staynest.demo.serviceimpl.*ServiceImpl.checkIn(..)) || " +
                    "execution(* com.staynest.demo.serviceimpl.*ServiceImpl.checkOut(..)) || " +
                    "execution(* com.staynest.demo.serviceimpl.*ServiceImpl.postCharge(..)) || " +
                    "execution(* com.staynest.demo.serviceimpl.*ServiceImpl.completeTask(..)) || " +
                    "execution(* com.staynest.demo.serviceimpl.*ServiceImpl.resolveRequest(..))")
    public void logAction(JoinPoint jp) {
        try {
            Authentication auth = SecurityContextHolder.getContext().getAuthentication();
            if (auth == null || !auth.isAuthenticated()) return;
            String email = auth.getName();
            usersRepository.findByEmail(email).ifPresent(user -> {
                String method = jp.getSignature().getName();
                String entity = jp.getTarget().getClass().getSimpleName().replace("ServiceImpl", "");
                auditLogService.createLog(user.getUserId(), method, entity);
            });
        } catch (Exception ignored) {}
    }
}
