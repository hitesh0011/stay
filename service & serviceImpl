    @Override
    public void deleteFolioItem(Integer id) {
        FolioItem item = folioItemRepository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("FolioItem not found with id: " + id));
        folioItemRepository.delete(item);
    }

    private FolioItemResponseDTO mapToResponse(FolioItem f) {
        return new FolioItemResponseDTO(f.getFolioItemId(), f.getStayRecord().getStayId(),
                f.getChargeType(), f.getDescription(), f.getAmount(), f.getPostedDate(),
                f.getPostedBy().getUserId(), f.getPostedBy().getName());
