package com.staynest.demo.serviceimpl;

import com.staynest.demo.dto.StayRecordRequestDTO;
import com.staynest.demo.dto.StayRecordResponseDTO;
import com.staynest.demo.entities.GuestProfile;
import com.staynest.demo.entities.Reservation;
import com.staynest.demo.entities.Room;
import com.staynest.demo.entities.StayRecord;
import com.staynest.demo.enums.RoomStatus;
import com.staynest.demo.enums.StayStatus;
import com.staynest.demo.exception.ResourceNotFoundException;
import com.staynest.demo.repositories.GuestProfileRepository;
import com.staynest.demo.repositories.ReservationRepository;
import com.staynest.demo.repositories.RoomRepository;
import com.staynest.demo.repositories.StayRecordRepository;
import com.staynest.demo.service.StayRecordService;
import java.time.LocalDateTime;
import java.util.List;
import java.util.stream.Collectors;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;

@Service
@RequiredArgsConstructor
public class StayRecordServiceImpl implements StayRecordService {

    private final StayRecordRepository stayRecordRepository;
    private final ReservationRepository reservationRepository;
    private final GuestProfileRepository guestProfileRepository;
    private final RoomRepository roomRepository;

    @Override
    public StayRecordResponseDTO checkIn(StayRecordRequestDTO dto) {
        Reservation reservation = reservationRepository.findById(dto.getReservationId())
                .orElseThrow(() -> new ResourceNotFoundException("Reservation not found with id: " + dto.getReservationId()));
        GuestProfile guest = guestProfileRepository.findById(dto.getGuestId())
                .orElseThrow(() -> new ResourceNotFoundException("Guest not found with id: " + dto.getGuestId()));
        Room room = roomRepository.findById(dto.getAssignedRoomId())
                .orElseThrow(() -> new ResourceNotFoundException("Room not found with id: " + dto.getAssignedRoomId()));

        StayRecord stay = new StayRecord();
        stay.setReservation(reservation);
        stay.setGuest(guest);
        stay.setAssignedRoom(room);
        stay.setActualCheckIn(LocalDateTime.now());
        stay.setFolioBalance(0);
        stay.setStatus(StayStatus.Active);

        room.setRoomStatus(RoomStatus.Occupied);
        roomRepository.save(room);

        return mapToResponse(stayRecordRepository.save(stay));
    }

    @Override
    public StayRecordResponseDTO getStayById(Integer id) {
        StayRecord stay = stayRecordRepository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("Stay not found with id: " + id));
        return mapToResponse(stay);
    }

    @Override
    public StayRecordResponseDTO getStayByReservation(Integer reservationId) {
        StayRecord stay = stayRecordRepository.findByReservation_ReservationId(reservationId)
                .orElseThrow(() -> new ResourceNotFoundException("Stay not found for reservationId: " + reservationId));
        return mapToResponse(stay);
    }

    @Override
    public List<StayRecordResponseDTO> getAllStays() {
        return stayRecordRepository.findAll().stream().map(this::mapToResponse).collect(Collectors.toList());
    }

    @Override
    public List<StayRecordResponseDTO> getStaysByStatus(StayStatus status) {
        return stayRecordRepository.findByStatus(status).stream().map(this::mapToResponse).collect(Collectors.toList());
    }

    @Override
    public StayRecordResponseDTO updateStay(Integer id, StayRecordRequestDTO dto) {
        StayRecord stay = stayRecordRepository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("Stay not found with id: " + id));
        stay.setFolioBalance(dto.getFolioBalance());
        if (dto.getStatus() != null) stay.setStatus(dto.getStatus());
        return mapToResponse(stayRecordRepository.save(stay));
    }

    @Override
    public StayRecordResponseDTO checkOut(Integer id) {
        StayRecord stay = stayRecordRepository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("Stay not found with id: " + id));
        stay.setActualCheckOut(LocalDateTime.now());
        stay.setStatus(StayStatus.CheckedOut);

        Room room = stay.getAssignedRoom();
        room.setRoomStatus(RoomStatus.Cleaning);
        roomRepository.save(room);

        return mapToResponse(stayRecordRepository.save(stay));
    }

    @Override
    public void deleteStay(Integer id) {
        StayRecord stay = stayRecordRepository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("Stay not found with id: " + id));
        stayRecordRepository.delete(stay);
    }

    private StayRecordResponseDTO mapToResponse(StayRecord s) {
        return new StayRecordResponseDTO(s.getStayId(), s.getReservation().getReservationId(),
                s.getGuest().getGuestId(), s.getGuest().getUsers().getName(),
                s.getAssignedRoom().getRoomId(), s.getAssignedRoom().getRoomNumber(),
                s.getActualCheckIn(), s.getActualCheckOut(), s.getFolioBalance(), s.getStatus());
    }
}

