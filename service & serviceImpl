                .orElseThrow(() -> new ResourceNotFoundException("Stay not found with id: " + id));
        stay.setActualCheckOut(LocalDateTime.now());
        stay.setStatus(StayStatus.CheckedOut);

        Room room = stay.getAssignedRoom();
        room.setRoomStatus(RoomStatus.Cleaning);
        roomRepository.save(room);

        return mapToResponse(stayRecordRepository.save(stay));
    }

    @Override
    public void deleteStay(Integer id) {
