@Service
@RequiredArgsConstructor
public class RatePlanServiceImpl implements RatePlanService {

    private final RatePlanRepository ratePlanRepository;
    private final RoomTypeRepository roomTypeRepository;

    @Override
    public RatePlanResponseDTO createRatePlan(RatePlanRequestDTO dto) {
        RoomType roomType = roomTypeRepository.findById(dto.getRoomTypeId())
                .orElseThrow(() -> new ResourceNotFoundException("RoomType not found with id: " + dto.getRoomTypeId()));
        RatePlan ratePlan = new RatePlan();
        ratePlan.setRoomType(roomType);
        ratePlan.setRatePlanType(dto.getRatePlanType());
        ratePlan.setPricePerNight(dto.getPricePerNight());
        ratePlan.setValidFrom(dto.getValidFrom());
        ratePlan.setValidTo(dto.getValidTo());
        ratePlan.setMealPlanIncluded(dto.getMealPlanIncluded());
        ratePlan.setRatePlanStatus(dto.getRatePlanStatus());
        return mapToResponse(ratePlanRepository.save(ratePlan));
    }

    @Override
    public RatePlanResponseDTO getRatePlanById(Integer id) {
        RatePlan ratePlan = ratePlanRepository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("RatePlan not found with id: " + id));
        return mapToResponse(ratePlan);
    }

    @Override
    public List<RatePlanResponseDTO> getAllRatePlans() {
        return ratePlanRepository.findAll().stream().map(this::mapToResponse).collect(Collectors.toList());
    }

    @Override
    public List<RatePlanResponseDTO> getRatePlansByRoomType(Integer roomTypeId) {
        return ratePlanRepository.findByRoomType_RoomTypeId(roomTypeId).stream()
                .map(this::mapToResponse).collect(Collectors.toList());
    }

    @Override
    public RatePlanResponseDTO updateRatePlan(Integer id, RatePlanRequestDTO dto) {
        RatePlan ratePlan = ratePlanRepository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("RatePlan not found with id: " + id));
        RoomType roomType = roomTypeRepository.findById(dto.getRoomTypeId())
                .orElseThrow(() -> new ResourceNotFoundException("RoomType not found with id: " + dto.getRoomTypeId()));
        ratePlan.setRoomType(roomType);
        ratePlan.setRatePlanType(dto.getRatePlanType());
        ratePlan.setPricePerNight(dto.getPricePerNight());
        ratePlan.setValidFrom(dto.getValidFrom());
        ratePlan.setValidTo(dto.getValidTo());
        ratePlan.setMealPlanIncluded(dto.getMealPlanIncluded());
        ratePlan.setRatePlanStatus(dto.getRatePlanStatus());
        return mapToResponse(ratePlanRepository.save(ratePlan));
    }

    @Override
    public void deleteRatePlan(Integer id) {
        RatePlan ratePlan = ratePlanRepository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("RatePlan not found with id: " + id));
        ratePlanRepository.delete(ratePlan);
    }

    private RatePlanResponseDTO mapToResponse(RatePlan rp) {
        return new RatePlanResponseDTO(rp.getRatePlanId(), rp.getRoomType().getRoomTypeId(),
                rp.getRoomType().getName().toString(), rp.getRatePlanType(), rp.getPricePerNight(),
                rp.getValidFrom(), rp.getValidTo(), rp.getMealPlanIncluded(), rp.getRatePlanStatus());
