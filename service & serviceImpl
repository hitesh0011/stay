@Service
@RequiredArgsConstructor
public class FolioItemServiceImpl implements FolioItemService {

    private final FolioItemRepository folioItemRepository;
    private final StayRecordRepository stayRecordRepository;
    private final UsersRepository usersRepository;

    @Override
    public FolioItemResponseDTO postCharge(FolioItemRequestDTO dto) {
        StayRecord stay = stayRecordRepository.findById(dto.getStayId())
                .orElseThrow(() -> new ResourceNotFoundException("Stay not found with id: " + dto.getStayId()));
        Users postedBy = usersRepository.findById(dto.getPostedBy())
                .orElseThrow(() -> new ResourceNotFoundException("User not found with id: " + dto.getPostedBy()));

        FolioItem item = new FolioItem();
        item.setStayRecord(stay);
        item.setChargeType(dto.getChargeType());
        item.setDescription(dto.getDescription());
        item.setAmount(dto.getAmount());
        item.setPostedDate(LocalDateTime.now());
        item.setPostedBy(postedBy);

        stay.setFolioBalance(stay.getFolioBalance() + dto.getAmount());
        stayRecordRepository.save(stay);

        return mapToResponse(folioItemRepository.save(item));
    }

    @Override
    public FolioItemResponseDTO getFolioItemById(Integer id) {
        FolioItem item = folioItemRepository.findById(id)
                .orElseThrow(() -> new ResourceNotFoundException("FolioItem not found with id: " + id));
