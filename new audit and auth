package com.staynest.demo.serviceimpl;

import com.staynest.demo.dto.AuthRequestDTO;
import com.staynest.demo.dto.AuthResponseDTO;
import com.staynest.demo.entities.Users;
import com.staynest.demo.exception.ResourceNotFoundException;
import com.staynest.demo.repositories.UsersRepository;
import com.staynest.demo.security.JwtUtil;
import com.staynest.demo.service.AuthService;
import lombok.RequiredArgsConstructor;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.stereotype.Service;

@Service
@RequiredArgsConstructor
public class AuthServiceImpl implements AuthService {

    private final UsersRepository usersRepository;
    private final PasswordEncoder passwordEncoder;
    private final JwtUtil jwtUtil;

    @Override
    public AuthResponseDTO login(AuthRequestDTO dto) {
        Users user = usersRepository.findByEmail(dto.getEmail())
                .orElseThrow(() -> new ResourceNotFoundException("User not found with email: " + dto.getEmail()));
        if (!passwordEncoder.matches(dto.getPassword(), user.getPassword()))
            throw new RuntimeException("Invalid credentials");
        String token = jwtUtil.generateToken(user.getEmail(), user.getRole().name());
        return new AuthResponseDTO(token, user.getRole().name());
    }
}
